# AVISO ARQUITETURAL: 
# Caracteres especiais na senha (como '#', '$', '@') DEVEM ser substituídos por
# seus respectivos valores em URL-Encoding (ex: '#' torna-se '%23').
# Caso contrário, o SQLAlchemy causará um crash silencioso de parsing da string!
DATABASE_URL="postgresql://[db-user].[project-ref]:[db-password]@aws-0-[region].pooler.supabase.com:6543/postgres"
